{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "devspace",
  "main": "src/worker.ts",
  "compatibility_date": "2026-07-09",
  "vars": {
    "DEVSPACE_DEVELOPMENT_USER_ID": "development-user"
  },
  "observability": {
    "enabled": true
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "REPOSITORIES",
        "class_name": "Repository"
      },
      {
        "name": "REPOSITORIES_GIT",
        "class_name": "RepositoryGit"
      },
      {
        "name": "CONTROL_PLANE",
        "class_name": "ControlPlane"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Repository"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["ControlPlane"]
    },
    {
      "tag": "v3",
      "new_sqlite_classes": ["RepositoryGit"]
    }
  ],
  "rules": [
    {
      "type": "CompiledWasm",
      "globs": ["**/*.wasm"],
      "fallthrough": true
    }
  ]
}
